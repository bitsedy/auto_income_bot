# ═══════════════════════════════════════════
# INCOME BOT PRO — ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════
# Copy this to .env and fill in every value.
# Each section explains where to get the key.

# ── AI PROVIDER (choose one) ─────────────────
# Claude API — https://console.anthropic.com/settings/keys
# Free tier gives $5 credit. Costs ~$0.006/day for Haiku drafting.
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI fallback (optional) — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ── PUBLISHING PLATFORMS ─────────────────────
# Dev.to — https://dev.to/settings/extensions → Generate API Key
DEVTO_API_KEY=4MF21AgNj6MVGswsJ68phYJ2

# Hashnode — https://hashnode.com/settings/developer → Generate Token
HASHNODE_API_TOKEN=49177e58-04d2-4e09-9c2e-4ee5a867f028
HASHNODE_PUBLICATION_ID=6a09e68c3104e2aff0b1da0b

# Medium — https://medium.com/me/settings/security → Integration tokens
MEDIUM_API_TOKEN=your-medium-token
MEDIUM_USER_ID=your-medium-user-id

# ── SOCIAL DISTRIBUTION ──────────────────────
# X/Twitter — https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret

# LinkedIn — https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token

# ── AFFILIATE PROGRAMS ───────────────────────
# Amazon Associates — https://affiliate-program.amazon.com
AMAZON_ASSOCIATE_TAG=your-tag-20
AMAZON_ACCESS_KEY=your-aws-access-key
AMAZON_SECRET_KEY=your-aws-secret-key
AMAZON_PARTNER_TAG=your-partner-tag

# Impact.com — https://app.impact.com
IMPACT_API_KEY=your-impact-api-key
IMPACT_ACCOUNT_SID=your-account-sid

# ShareASale — https://account.shareasale.com
SHAREASALE_API_KEY=your-shareasale-key
SHAREASALE_API_SECRET=your-shareasale-secret
SHAREASALE_MERCHANT_ID=your-merchant-id

# ── DIGITAL PRODUCTS ─────────────────────────
# Gumroad — https://app.gumroad.com/settings/advanced
GUMROAD_ACCESS_TOKEN=J20atrpqTR_d81O2rddw-cKBmFd_ThFzVoE35nvmltM

# ── LINK TRACKING ────────────────────────────
# Dub.co — https://dub.co → Settings → API Keys (free tier)
DUBCO_API_KEY=your-dubco-api-key
DUBCO_WORKSPACE_SLUG=your-workspace-slug

# ── EMAIL REPORTS ────────────────────────────
# Resend — https://resend.com/api-keys (3,000 emails/month free)
RESEND_API_KEY=re_your-resend-key
REPORT_EMAIL_TO=you@example.com
REPORT_EMAIL_FROM=bot@yourdomain.com

# ── GITHUB ACTIONS ───────────────────────────
# Used for dashboard deployment & stats persistence
GITHUB_TOKEN=ghp_your-github-token
GITHUB_REPO=your-username/income-bot-pro

# ── OPTIONAL: KO-FI TIP JAR ──────────────────
KOFI_PAGE_URL=https://ko-fi.com/yourpage

# ── COST CONTROLS ────────────────────────────
MAX_DAILY_API_SPEND_USD=0.50
MAX_ARTICLES_PER_RUN=3
QUALITY_THRESHOLD=0.75

# ── NICHE TARGETING ──────────────────────────
# Comma-separated: niches with highest affiliate potential
TARGET_NICHES=tech-gadgets,home-office,software-reviews,developer-tools,productivity